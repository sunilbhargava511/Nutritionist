# Production Environment Variables for Railway

# Server Configuration
NODE_ENV=production
PORT=3000

# Database - Railway will provide DATABASE_URL
DATABASE_URL=file:./database.sqlite

# Authentication - REQUIRED
JWT_SECRET=generate-a-secure-random-string-here
SESSION_SECRET=generate-another-secure-random-string-here

# Google OAuth - REQUIRED
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://your-app.up.railway.app/api/auth/google/callback

# OpenAI - REQUIRED
OPENAI_API_KEY=your-openai-api-key

# 11Labs - REQUIRED
ELEVENLABS_API_KEY=your-11labs-api-key
ELEVENLABS_VOICE_ID=your-default-voice-id

# Frontend URL - Update with your Railway URL
FRONTEND_URL=https://your-app.up.railway.app

# Redis URL (optional - Railway can provide)
# REDIS_URL=redis://default:password@host:port

# Application Settings
MAX_FREE_CONVERSATION_MINUTES=3
CONVERSATION_REPORT_DELAY_MS=5000