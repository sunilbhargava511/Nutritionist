{
  "name": "nutritionist-assistant",
  "version": "1.0.0",
  "description": "AI-powered nutritionist assistant platform",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "build:start": "npm run build && npm run start",
    "start:prod": "node dist/server.js",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "test": "jest",
    "postinstall": "npm run build || echo 'Build failed but continuing'",
    "railway:build": "npm run build",
    "railway:start": "npm start"
  },
  "keywords": [
    "nutrition",
    "health",
    "ai",
    "assistant"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@types/passport-jwt": "^4.0.1",
    "axios": "^1.6.2",
    "bcrypt": "^5.1.1",
    "bull": "^4.11.5",
    "cheerio": "^1.0.0-rc.12",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.6.0",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.24.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "pdf-parse": "^1.1.1",
    "rate-limiter-flexible": "^3.0.5",
    "redis": "^4.6.11",
    "sequelize": "^6.35.2",
    "socket.io": "^4.6.0",
    "sqlite3": "^5.1.6",
    "winston": "^3.11.0",
    "youtube-transcript": "^1.0.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.17.10",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.5",
    "@types/passport": "^1.0.16",
    "@types/passport-google-oauth20": "^2.0.14",
    "@types/pdf-parse": "^1.1.5",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "ts-jest": "^29.1.1",
    "tsx": "^4.6.2",
    "typescript": "^5.3.3"
  }
}
